<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Taxnara — Konsultan Pajak UMKM & Freelancer</title>
  <meta name="description" content="Konsultan Pajak Profesional untuk UMKM, freelancer, dan pekerja gig. Hemat pajak, bebas denda, aman dari audit. Dapatkan toolkit pajak gratis sekarang." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    /* ===========================
       CSS CUSTOM PROPERTIES
    =========================== */
    :root {
      --teal:        #0F766E;
      --teal-dark:   #0a5c56;
      --teal-light:  #14b8a6;
      --orange:      #F59E0B;
      --orange-dark: #d97706;
      --beige:       #FEF3C7;
      --cream:       #FFFBEB;
      --text:        #1F2937;
      --text-light:  #6B7280;
      --white:       #FFFFFF;
      --border:      #E5E7EB;
      --shadow:      0 4px 24px rgba(15,118,110,0.10);
      --shadow-lg:   0 8px 40px rgba(15,118,110,0.18);
      --radius:      12px;
      --radius-lg:   20px;
      --font:        'Montserrat', sans-serif;
      --transition:  0.3s cubic-bezier(.4,0,.2,1);
    }

    /* ===========================
       RESET & BASE
    =========================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--cream);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }

    /* ===========================
       UTILITY
    =========================== */
    .container { max-width: 1140px; margin: 0 auto; padding: 0 20px; }
    .section { padding: 80px 0; }
    .section-sm { padding: 56px 0; }
    .text-center { text-align: center; }
    .text-teal { color: var(--teal); }
    .text-orange { color: var(--orange); }
    .badge {
      display: inline-block;
      background: var(--beige);
      color: var(--teal);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 999px;
      border: 1.5px solid rgba(15,118,110,.2);
      margin-bottom: 18px;
    }
    .section-title {
      font-size: clamp(26px, 4vw, 40px);
      font-weight: 800;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 16px;
    }
    .section-sub {
      font-size: 16px;
      color: var(--text-light);
      max-width: 620px;
      margin: 0 auto 48px;
      line-height: 1.75;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 15px 32px;
      border-radius: 999px;
      font-family: var(--font);
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      border: none;
      transition: var(--transition);
      text-decoration: none;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--orange);
      color: var(--white);
      box-shadow: 0 4px 20px rgba(245,158,11,.35);
    }
    .btn-primary:hover {
      background: var(--orange-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(245,158,11,.45);
    }
    .btn-teal {
      background: var(--teal);
      color: var(--white);
      box-shadow: 0 4px 20px rgba(15,118,110,.3);
    }
    .btn-teal:hover {
      background: var(--teal-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(15,118,110,.4);
    }
    .btn-outline {
      background: transparent;
      color: var(--teal);
      border: 2px solid var(--teal);
    }
    .btn-outline:hover {
      background: var(--teal);
      color: var(--white);
    }
    .btn-lg { padding: 18px 40px; font-size: 17px; }

    /* ===========================
       NAVBAR
    =========================== */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      background: rgba(255,251,235,.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(15,118,110,.1);
      transition: box-shadow var(--transition);
    }
    .navbar.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,.08); }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
      gap: 32px;
    }
    .nav-logo {
      font-size: 22px;
      font-weight: 900;
      color: var(--teal);
      letter-spacing: -.02em;
    }
    .nav-logo span { color: var(--orange); }
    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
    }
    .nav-links a {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      transition: color var(--transition);
    }
    .nav-links a:hover { color: var(--teal); }
    .nav-cta { display: flex; gap: 12px; align-items: center; }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 24px; height: 2.5px;
      background: var(--text);
      border-radius: 2px;
      transition: var(--transition);
    }

    /* ===========================
       HERO
    =========================== */
    .hero {
      min-height: 100vh;
      background: linear-gradient(135deg, #0a5c56 0%, #0F766E 40%, #14b8a6 100%);
      display: flex;
      align-items: center;
      padding-top: 68px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    /* decorative circles */
    .hero::after {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: rgba(255,255,255,.04);
      top: -100px; right: -150px;
      pointer-events: none;
    }
    .hero-deco {
      position: absolute;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: rgba(245,158,11,.12);
      bottom: -80px; left: -80px;
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 1;
      padding: 80px 0;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.15);
      color: var(--beige);
      font-size: 13px;
      font-weight: 600;
      padding: 8px 18px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.25);
      margin-bottom: 24px;
      backdrop-filter: blur(8px);
    }
    .hero-badge .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--orange);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: .6; transform: scale(1.3); }
    }
    .hero-title {
      font-size: clamp(32px, 4.5vw, 54px);
      font-weight: 900;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 20px;
      letter-spacing: -.02em;
    }
    .hero-title .highlight {
      color: var(--orange);
      position: relative;
    }
    .hero-sub {
      font-size: clamp(16px, 2vw, 19px);
      color: rgba(255,255,255,.85);
      margin-bottom: 36px;
      line-height: 1.7;
    }
    .hero-trust {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      margin-top: 24px;
    }
    .hero-trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: rgba(255,255,255,.8);
      font-weight: 600;
    }
    .hero-trust-item .check { color: var(--orange); font-size: 16px; }

    /* Hero Form Card */
    .hero-form-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 40px 36px;
      box-shadow: var(--shadow-lg);
      position: relative;
      animation: floatIn .8s ease both;
    }
    @keyframes floatIn {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .form-card-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--beige);
      color: var(--orange-dark);
      font-size: 12px;
      font-weight: 700;
      padding: 5px 14px;
      border-radius: 999px;
      margin-bottom: 16px;
    }
    .form-card-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 6px;
    }
    .form-card-sub {
      font-size: 14px;
      color: var(--text-light);
      margin-bottom: 24px;
      line-height: 1.6;
    }
    .form-group { margin-bottom: 16px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 6px;
    }
    .form-group input {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      font-family: var(--font);
      font-size: 14px;
      color: var(--text);
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
      background: #fafafa;
    }
    .form-group input:focus {
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(15,118,110,.12);
      background: #fff;
    }
    .form-group input::placeholder { color: #aaa; }
    .form-submit {
      width: 100%;
      padding: 15px;
      border-radius: var(--radius);
      font-family: var(--font);
      font-size: 15px;
      font-weight: 700;
      background: var(--orange);
      color: var(--white);
      border: none;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 4px 20px rgba(245,158,11,.35);
    }
    .form-submit:hover {
      background: var(--orange-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(245,158,11,.45);
    }
    .form-note {
      text-align: center;
      font-size: 12px;
      color: var(--text-light);
      margin-top: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }

    /* toolkit preview */
    .toolkit-preview {
      background: var(--beige);
      border-radius: 10px;
      padding: 14px 18px;
      margin-bottom: 20px;
    }
    .toolkit-preview-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--teal);
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 10px;
    }
    .toolkit-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 13px;
      color: var(--text);
      margin-bottom: 7px;
      animation: slideIn .4s ease both;
    }
    .toolkit-item:nth-child(1) { animation-delay: .1s; }
    .toolkit-item:nth-child(2) { animation-delay: .2s; }
    .toolkit-item:nth-child(3) { animation-delay: .3s; }
    .toolkit-item:nth-child(4) { animation-delay: .4s; }
    .toolkit-item:nth-child(5) { animation-delay: .5s; }
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-10px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .toolkit-item .icon { color: var(--teal); font-size: 15px; flex-shrink: 0; margin-top: 1px; }

    /* ===========================
       STATS BAR
    =========================== */
    .stats-bar {
      background: var(--teal);
      padding: 40px 0;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      text-align: center;
    }
    .stat-item {}
    .stat-num {
      font-size: 36px;
      font-weight: 900;
      color: var(--white);
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-num span { color: var(--orange); }
    .stat-label { font-size: 13px; color: rgba(255,255,255,.75); font-weight: 500; }

    /* ===========================
       PROBLEM SECTION
    =========================== */
    .problem { background: var(--white); }
    .pain-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .pain-card {
      background: var(--cream);
      border-radius: var(--radius-lg);
      padding: 32px 28px;
      border: 1.5px solid var(--border);
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }
    .pain-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(15,118,110,.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .pain-card:hover {
      border-color: var(--teal-light);
      transform: translateY(-4px);
      box-shadow: var(--shadow);
    }
    .pain-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--beige);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin-bottom: 18px;
    }
    .pain-title { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--text); }
    .pain-desc { font-size: 14px; color: var(--text-light); line-height: 1.7; }

    /* ===========================
       TOOLKIT SECTION
    =========================== */
    .toolkit { background: linear-gradient(135deg, var(--cream) 0%, #fff 100%); }
    .toolkit-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .toolkit-heading { text-align: left; margin-bottom: 0; }
    .toolkit-list { margin-top: 28px; display: flex; flex-direction: column; gap: 16px; }
    .toolkit-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 18px 20px;
      background: var(--white);
      border-radius: var(--radius);
      border: 1.5px solid var(--border);
      transition: var(--transition);
    }
    .toolkit-row:hover {
      border-color: var(--teal-light);
      box-shadow: var(--shadow);
    }
    .toolkit-row-icon {
      width: 44px; height: 44px; flex-shrink: 0;
      border-radius: 12px;
      background: var(--beige);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .toolkit-row-text {}
    .toolkit-row-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
    .toolkit-row-desc { font-size: 13px; color: var(--text-light); }

    /* Right side: form repeat */
    .toolkit-form-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 40px 36px;
      box-shadow: var(--shadow-lg);
      border: 1.5px solid rgba(15,118,110,.1);
    }
    .toolkit-form-title { font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
    .toolkit-form-sub { font-size: 14px; color: var(--text-light); margin-bottom: 24px; }

    /* ===========================
       VALUE PROPOSITION
    =========================== */
    .value { background: var(--cream); }
    .value-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .value-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 36px 28px;
      text-align: center;
      border: 1.5px solid var(--border);
      transition: var(--transition);
    }
    .value-card:hover {
      border-color: var(--teal);
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }
    .value-icon {
      width: 68px; height: 68px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--beige), #fff);
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      margin: 0 auto 20px;
      border: 2px solid rgba(15,118,110,.12);
    }
    .value-title { font-size: 16px; font-weight: 800; color: var(--teal); margin-bottom: 10px; }
    .value-desc { font-size: 14px; color: var(--text-light); line-height: 1.7; }

    /* ===========================
       TEAM
    =========================== */
    .team { background: var(--white); }
    .team-card {
      max-width: 700px;
      margin: 0 auto;
      background: linear-gradient(135deg, var(--cream), #fff);
      border-radius: var(--radius-lg);
      padding: 48px;
      display: flex;
      gap: 40px;
      align-items: center;
      border: 1.5px solid rgba(15,118,110,.15);
      box-shadow: var(--shadow);
    }
    .team-avatar {
      width: 140px; height: 140px; flex-shrink: 0;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal), var(--teal-light));
      display: flex; align-items: center; justify-content: center;
      font-size: 56px;
      border: 4px solid var(--beige);
    }
    .team-name { font-size: 24px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
    .team-role { font-size: 15px; color: var(--teal); font-weight: 600; margin-bottom: 12px; }
    .team-license {
      display: inline-block;
      background: var(--beige);
      color: var(--text-light);
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 6px;
      margin-bottom: 14px;
    }
    .team-bio { font-size: 14px; color: var(--text-light); line-height: 1.7; }
    .team-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .team-tag {
      background: var(--teal);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 999px;
    }

    /* ===========================
       TESTIMONIALS
    =========================== */
    .testimonials { background: var(--cream); }
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 48px;
    }
    .testi-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 32px 28px;
      border: 1.5px solid var(--border);
      transition: var(--transition);
      position: relative;
    }
    .testi-card:hover {
      border-color: var(--teal-light);
      box-shadow: var(--shadow);
    }
    .testi-stars { color: var(--orange); font-size: 15px; margin-bottom: 14px; letter-spacing: 2px; }
    .testi-quote { font-size: 14px; color: var(--text); line-height: 1.75; margin-bottom: 20px; font-style: italic; }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal), var(--teal-light));
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .testi-name { font-size: 14px; font-weight: 700; color: var(--text); }
    .testi-biz { font-size: 12px; color: var(--text-light); }

    /* ===========================
       PRICING
    =========================== */
    .pricing { background: var(--white); }
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .pricing-card {
      background: var(--cream);
      border-radius: var(--radius-lg);
      padding: 40px 32px;
      border: 1.5px solid var(--border);
      position: relative;
      transition: var(--transition);
    }
    .pricing-card.featured {
      background: var(--teal);
      border-color: var(--teal);
      transform: scale(1.04);
      box-shadow: var(--shadow-lg);
    }
    .pricing-card:not(.featured):hover {
      border-color: var(--teal);
      box-shadow: var(--shadow);
    }
    .pricing-badge {
      position: absolute;
      top: -14px; left: 50%;
      transform: translateX(-50%);
      background: var(--orange);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 5px 16px;
      border-radius: 999px;
      white-space: nowrap;
    }
    .pricing-name { font-size: 18px; font-weight: 800; margin-bottom: 4px; }
    .pricing-desc { font-size: 13px; margin-bottom: 20px; }
    .pricing-card:not(.featured) .pricing-name { color: var(--text); }
    .pricing-card:not(.featured) .pricing-desc { color: var(--text-light); }
    .pricing-card.featured .pricing-name,
    .pricing-card.featured .pricing-desc { color: rgba(255,255,255,.85); }
    .pricing-original { font-size: 14px; text-decoration: line-through; margin-bottom: 4px; }
    .pricing-card:not(.featured) .pricing-original { color: var(--text-light); }
    .pricing-card.featured .pricing-original { color: rgba(255,255,255,.55); }
    .pricing-price { font-size: 32px; font-weight: 900; margin-bottom: 24px; }
    .pricing-card:not(.featured) .pricing-price { color: var(--teal); }
    .pricing-card.featured .pricing-price { color: var(--white); }
    .pricing-price small { font-size: 15px; font-weight: 500; }
